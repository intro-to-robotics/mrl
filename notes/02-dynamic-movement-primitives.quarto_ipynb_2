        "axes[0, 1].scatter(g[0], g[1], color=\"crimson\", marker=\"*\", s=80, label=\"goal\")\n",
        "axes[0, 1].set_title(\"Fitted Result\")\n",
        "axes[0, 1].set_xlabel(r\"$q_1$\")\n",
        "axes[0, 1].set_ylabel(r\"$q_2$\")\n",
        "axes[0, 1].set_aspect(\"equal\", adjustable=\"box\")\n",
        "axes[0, 1].grid(alpha=0.3)\n",
        "axes[0, 1].legend(loc=\"best\")\n",
        "\n",
        "# (1,3) animated convergence\n",
        "axes[0, 2].plot(q_fit[:, 0], q_fit[:, 1], color=\"lightgray\", linewidth=2, linestyle=\"--\")\n",
        "axes[0, 2].scatter(g[0], g[1], color=\"crimson\", marker=\"*\", s=80, label=\"goal\")\n",
        "traj_line, = axes[0, 2].plot([], [], color=\"tab:blue\", linewidth=2.2, label=\"trajectory\")\n",
        "particle, = axes[0, 2].plot([], [], \"o\", color=\"tab:orange\", markersize=7, label=\"particle\")\n",
