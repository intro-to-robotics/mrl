        "axes[0, 0].set_xlabel(r\"$q_1$\")\n",
        "axes[0, 0].set_ylabel(r\"$q_2$\")\n",
        "axes[0, 0].set_aspect(\"equal\", adjustable=\"box\")\n",
        "axes[0, 0].grid(alpha=0.3)\n",
        "\n",
        "# (1,2) fitted result\n",
        "axes[0, 1].plot(q_demo[:, 0], q_demo[:, 1], \"--\", color=\"gray\", linewidth=2, label=\"demo\")\n",
