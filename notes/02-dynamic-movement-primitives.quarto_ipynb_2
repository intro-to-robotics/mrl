        "#| code-fold: true\n",
        "#| code-summary: \"Show Python code\"\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from matplotlib.animation import FuncAnimation, PillowWriter\n",
        "from pathlib import Path\n",
        "import subprocess\n",
        "\n",
        "# 1) Build a demonstration and learn theta once\n",
        "T = 2.0\n",
        "h = 0.01\n",
        "t = np.arange(0.0, T + h, h)\n",
        "M = len(t)\n",
        "\n",
        "tau = t / T\n",
        "x_demo = -1.0 + 2.0 * tau\n",
        "base_s = x_demo**5 - x_demo\n",
        "wiggle = np.sin(4.0 * np.pi * tau) * (1.0 - (2.0 * tau - 1.0) ** 2)\n",
        "y_demo = 1.6 * base_s + 0.25 * wiggle\n",
        "q_demo = np.column_stack([x_demo, y_demo])\n",
        "\n",
        "qd_demo = np.gradient(q_demo, h, axis=0)\n",
        "qdd_demo = np.gradient(qd_demo, h, axis=0)\n",
        "\n",
        "N = 35\n",
        "s = np.maximum(1.0 - t / T, 0.0)\n",
        "c = np.linspace(0.0, 1.0, N)\n",
        "delta = 1.0 / (N - 1)\n",
        "psi = np.exp(-((s[:, None] - c[None, :]) ** 2) / (delta**2))\n",
        "Phi = (psi / (psi.sum(axis=1, keepdims=True) + 1e-12)) * s[:, None]  # M x N\n",
        "\n",
        "K = np.diag([100.0, 100.0])\n",
        "D = np.diag([20.0, 20.0])\n",
        "g0 = q_demo[-1]\n",
        "f_target = qdd_demo - (K @ (g0 - q_demo).T).T + (D @ qd_demo.T).T  # M x 2\n",
        "\n",
        "lam = 1e-4\n",
        "A = Phi.T @ Phi + lam * np.eye(N)\n",
        "theta = np.linalg.solve(A, Phi.T @ f_target).T  # 2 x N\n",
        "\n",
        "# 2) Rollout function for a given goal\n",
        "def rollout(goal):\n",
        "    q = np.zeros((M, 2))\n",
        "    qd = np.zeros((M, 2))\n",
        "    q[0] = q_demo[0]\n",
        "    for k in range(M - 1):\n",
        "        f_hat = theta @ Phi[k]\n",
        "        qdd = K @ (goal - q[k]) - D @ qd[k] + f_hat\n",
        "        qd[k + 1] = qd[k] + h * qdd\n",
        "        q[k + 1] = q[k] + h * qd[k]\n",
        "    return q\n",
        "\n",
        "# 3) Original + three goal changes\n",
        "goals = [\n",
        "    (\"Original Goal\", g0),\n",
        "    (\"Goal Change 1\", g0 + np.array([0.35, 0.00])),\n",
        "    (\"Goal Change 2\", g0 + np.array([0.00, -0.35])),\n",
        "    (\"Goal Change 3\", g0 + np.array([0.30, 0.25])),\n",
        "]\n",
        "trajs = [rollout(g) for _, g in goals]\n",
        "\n",
        "# 4) Build a (1,4) animated figure\n",
        "fig, axes = plt.subplots(1, 4, figsize=(16, 4.2), constrained_layout=True)\n",
