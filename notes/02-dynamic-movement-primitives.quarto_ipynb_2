        "#| code-fold: true\n",
        "#| code-summary: \"Show Python code\"\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from matplotlib.animation import FuncAnimation, PillowWriter\n",
        "from pathlib import Path\n",
        "import subprocess\n",
        "rng = np.random.default_rng(7)\n",
        "\n",
        "# DMP setup (2D particle)\n",
        "T = 2.0\n",
        "h = 0.01\n",
        "t = np.arange(0.0, T + h, h)\n",
        "K = np.diag([80.0, 80.0])\n",
        "D = np.diag([18.0, 18.0])\n",
        "q0 = np.array([-0.8, -0.6])\n",
        "g = np.array([1.0, 0.8])\n",
        "N = 30\n",
        "\n",
        "# Phase variable and RBF dictionary\n",
        "s = np.maximum(1.0 - t / T, 0.0)\n",
        "c = np.linspace(0.0, 1.0, N)\n",
        "delta = 1.0 / (N - 1)\n",
        "\n",
        "# Random parameter matrix theta in R^{2 x N}\n",
        "theta = rng.normal(loc=0.0, scale=50.0, size=(2, N))\n",
        "psi = np.exp(-((s[:, None] - c[None, :]) ** 2) / (delta**2))\n",
        "weights = psi / (psi.sum(axis=1, keepdims=True) + 1e-12)\n",
        "f = (weights @ theta.T) * s[:, None]\n",
        "\n",
        "# Discrete-time DMP rollout (2D)\n",
        "q = np.zeros((len(t), 2))\n",
        "qd = np.zeros((len(t), 2))\n",
        "qdd = np.zeros((len(t), 2))\n",
        "q[0] = q0\n",
        "\n",
        "for k in range(len(t) - 1):\n",
        "    qdd[k] = K @ (g - q[k]) - D @ qd[k] + f[k]\n",
        "    qd[k + 1] = qd[k] + h * qdd[k]\n",
        "    q[k + 1] = q[k] + h * qd[k]\n",
        "qdd[-1] = K @ (g - q[-1]) - D @ qd[-1] + f[-1]\n",
        "\n",
        "# Build a single (1,2) figure/GIF\n",
        "fig, axes = plt.subplots(1, 2, figsize=(11, 5), constrained_layout=True)\n",
        "\n",
        "# Left: full trajectory overview\n",
        "axes[0].plot(q[:, 0], q[:, 1], color=\"tab:blue\", linewidth=2.5, label=\"q_des(t)\")\n",
        "axes[0].scatter(q0[0], q0[1], color=\"black\", s=40, label=\"start\")\n",
        "axes[0].scatter(g[0], g[1], color=\"crimson\", s=80, marker=\"*\", label=\"goal\")\n",
        "axes[0].set_title(\"Trajectory Overview\")\n",
        "axes[0].set_xlabel(r\"$q_1$\")\n",
        "axes[0].set_ylabel(r\"$q_2$\")\n",
        "axes[0].set_aspect(\"equal\", adjustable=\"box\")\n",
        "axes[0].grid(alpha=0.3)\n",
        "axes[0].legend(loc=\"best\")\n",
        "\n",
        "# Right: animated convergence\n",
        "axes[1].plot(q[:, 0], q[:, 1], color=\"lightgray\", linewidth=2.0, linestyle=\"--\")\n",
        "axes[1].scatter(g[0], g[1], color=\"crimson\", s=80, marker=\"*\", label=\"goal\")\n",
        "traj_line, = axes[1].plot([], [], color=\"tab:blue\", linewidth=2.2, label=\"trajectory\")\n",
        "particle, = axes[1].plot([], [], \"o\", color=\"tab:orange\", markersize=7, label=\"particle\")\n",
        "axes[1].set_title(\"Converging Particle\")\n",
        "axes[1].set_xlabel(r\"$q_1$\")\n",
        "axes[1].set_ylabel(r\"$q_2$\")\n",
        "axes[1].set_aspect(\"equal\", adjustable=\"box\")\n",
        "axes[1].grid(alpha=0.3)\n",
        "axes[1].legend(loc=\"best\")\n",
        "\n",
        "pad = 0.2\n",
        "xlim = (min(q[:, 0].min(), g[0]) - pad, max(q[:, 0].max(), g[0]) + pad)\n",
        "ylim = (min(q[:, 1].min(), g[1]) - pad, max(q[:, 1].max(), g[1]) + pad)\n",
        "for ax in axes:\n",
        "    ax.set_xlim(*xlim)\n",
        "    ax.set_ylim(*ylim)\n",
        "\n",
        "def update(frame_idx):\n",
        "    traj_line.set_data(q[: frame_idx + 1, 0], q[: frame_idx + 1, 1])\n",
        "    particle.set_data([q[frame_idx, 0]], [q[frame_idx, 1]])\n",
