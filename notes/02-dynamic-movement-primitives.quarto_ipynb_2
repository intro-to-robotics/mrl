        "#| code-fold: true\n",
        "#| code-summary: \"Show Python code\"\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from matplotlib.animation import FuncAnimation, PillowWriter\n",
        "from pathlib import Path\n",
        "import subprocess\n",
        "\n",
        "# 1) Synthetic S-shaped demonstration in R^2\n",
        "T = 2.0\n",
        "h = 0.01\n",
        "t = np.arange(0.0, T + h, h)\n",
        "M = len(t)\n",
        "\n",
        "tau = t / T\n",
        "x_demo = -1.0 + 2.0 * tau\n",
        "base_s = x_demo**5 - x_demo\n",
        "wiggle = np.sin(4.0 * np.pi * tau) * (1.0 - (2.0 * tau - 1.0) ** 2)\n",
        "y_demo = 1.6 * base_s + 0.25 * wiggle\n",
        "q_demo = np.column_stack([x_demo, y_demo])\n",
        "\n",
        "# Numerical derivatives from demonstration\n",
        "qd_demo = np.gradient(q_demo, h, axis=0)\n",
        "qdd_demo = np.gradient(qd_demo, h, axis=0)\n",
        "\n",
        "# 2) DMP basis features\n",
        "N = 35\n",
        "s = np.maximum(1.0 - t / T, 0.0)\n",
        "c = np.linspace(0.0, 1.0, N)\n",
        "delta = 1.0 / (N - 1)\n",
        "\n",
        "psi = np.exp(-((s[:, None] - c[None, :]) ** 2) / (delta**2))\n",
        "Phi = (psi / (psi.sum(axis=1, keepdims=True) + 1e-12)) * s[:, None]  # M x N\n",
        "\n",
        "# 3) Ridge regression for theta\n",
        "K = np.diag([100.0, 100.0])\n",
        "D = np.diag([20.0, 20.0])\n",
        "g = q_demo[-1]\n",
        "\n",
        "f_target = qdd_demo - (K @ (g - q_demo).T).T + (D @ qd_demo.T).T  # M x 2\n",
        "\n",
        "lam = 1e-4\n",
        "A = Phi.T @ Phi + lam * np.eye(N)  # N x N\n",
        "theta_T = np.linalg.solve(A, Phi.T @ f_target)  # N x 2\n",
        "theta = theta_T.T  # 2 x N\n",
        "\n",
        "# 4) Rollout fitted DMP trajectory\n",
        "q_fit = np.zeros_like(q_demo)\n",
        "qd_fit = np.zeros_like(q_demo)\n",
        "f_all = np.zeros_like(q_demo)\n",
        "q_fit[0] = q_demo[0]\n",
        "\n",
        "for k in range(M - 1):\n",
