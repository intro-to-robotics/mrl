        "pad = 0.18\n",
        "xlim = (all_x.min() - pad, all_x.max() + pad)\n",
        "ylim = (all_y.min() - pad, all_y.max() + pad)\n",
        "\n",
        "traj_lines = []\n",
        "particles = []\n",
        "for idx, ((title, goal), q_roll) in enumerate(zip(goals, trajs)):\n",
