        "    q_fit[k + 1] = q_fit[k] + h * qd_fit[k]\n",
        "f_all[-1] = theta @ Phi[-1]\n",
        "\n",
        "# 5) Build a single (2,3) animated figure\n",
        "fig, axes = plt.subplots(2, 3, figsize=(14, 8), constrained_layout=True)\n",
