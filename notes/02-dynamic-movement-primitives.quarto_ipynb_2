        "    ax.plot(q_demo[:, 0], q_demo[:, 1], \"--\", color=\"gray\", linewidth=1.8, label=\"demo shape\")\n",
        "    ax.scatter(q_demo[0, 0], q_demo[0, 1], color=\"black\", s=28, label=\"start\")\n",
        "    ax.scatter(goal[0], goal[1], color=\"crimson\", marker=\"*\", s=70, label=\"goal\")\n",
        "    line, = ax.plot([], [], color=\"tab:blue\", linewidth=2.2, label=\"DMP rollout\")\n",
        "    pt, = ax.plot([], [], \"o\", color=\"tab:orange\", markersize=6)\n",
        "    traj_lines.append(line)\n",
        "    particles.append(pt)\n",
        "    ax.set_title(title)\n",
        "    ax.set_xlabel(r\"$q_1$\")\n",
        "    if idx == 0:\n",
        "        ax.set_ylabel(r\"$q_2$\")\n",
        "    ax.set_aspect(\"equal\", adjustable=\"box\")\n",
        "    ax.set_xlim(*xlim)\n",
        "    ax.set_ylim(*ylim)\n",
        "    ax.grid(alpha=0.3)\n",
        "    if idx == 0:\n",
