      "source": [
        "#| code-fold: true\n",
        "#| code-summary: \"Show Python code\"\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# 1) Build a demonstration and learn theta\n",
        "T = 2.0\n",
        "h = 0.005\n",
        "t = np.arange(0.0, T + h, h)\n",
        "M = len(t)\n",
        "\n",
        "tau = t / T\n",
        "x_demo = -1.0 + 2.0 * tau\n",
        "base_s = x_demo**5 - x_demo\n",
        "wiggle = np.sin(4.0 * np.pi * tau) * (1.0 - (2.0 * tau - 1.0) ** 2)\n",
        "y_demo = 1.6 * base_s + 0.25 * wiggle\n",
        "q_demo = np.column_stack([x_demo, y_demo])\n",
        "\n",
        "qd_demo = np.gradient(q_demo, h, axis=0)\n",
        "qdd_demo = np.gradient(qd_demo, h, axis=0)\n",
        "\n",
        "N = 35\n",
        "s = np.maximum(1.0 - t / T, 0.0)\n",
        "c = np.linspace(0.0, 1.0, N)\n",
        "delta = 1.0 / (N - 1)\n",
        "psi = np.exp(-((s[:, None] - c[None, :]) ** 2) / (delta**2))\n",
        "Phi = (psi / (psi.sum(axis=1, keepdims=True) + 1e-12)) * s[:, None]  # M x N\n",
        "\n",
        "K_dmp = np.diag([100.0, 100.0])\n",
        "D_dmp = np.diag([20.0, 20.0])\n",
        "g = q_demo[-1]\n",
        "\n",
        "f_target = qdd_demo - (K_dmp @ (g - q_demo).T).T + (D_dmp @ qd_demo.T).T\n",
        "lam = 1e-4\n",
        "A = Phi.T @ Phi + lam * np.eye(N)\n",
        "theta = np.linalg.solve(A, Phi.T @ f_target).T  # 2 x N\n",
        "\n",
        "# 2) Two policy variants with the same low-level high-stiffness PD controller\n",
        "Kp_ll = np.diag([450.0, 450.0])\n",
        "Kd_ll = np.diag([60.0, 60.0])\n",
        "\n",
        "t_push_start = 0.90\n",
        "t_push_end = 1.10\n",
        "push = np.array([500.0, -200.0])  # large external perturbation\n",
        "\n",
        "def simulate(mode):\n",
        "    q_act = np.zeros((M, 2))\n",
        "    qd_act = np.zeros((M, 2))\n",
        "    q_des = np.zeros((M, 2))\n",
        "    qd_des = np.zeros((M, 2))\n",
        "    qdd_des = np.zeros((M, 2))\n",
        "\n",
        "    q_act[0] = q_demo[0]\n",
        "    q_des[0] = q_demo[0]\n",
        "\n",
        "    for k in range(M - 1):\n",
        "        f_hat = theta @ Phi[k]\n",
        "\n",
        "        if mode == \"clock_only\":\n",
        "            # Open-loop desired dynamics driven only by internal clock t\n",
        "            qdd_des[k] = K_dmp @ (g - q_des[k]) - D_dmp @ qd_des[k] + f_hat\n",
        "        elif mode == \"feedback\":\n",
        "            # Desired acceleration is computed from actual proprioceptive state\n",
        "            qdd_des[k] = K_dmp @ (g - q_act[k]) - D_dmp @ qd_act[k] + f_hat\n",
        "        else:\n",
        "            raise ValueError(\"Unknown mode.\")\n",
        "\n",
        "        qd_des[k + 1] = qd_des[k] + h * qdd_des[k]\n",
        "        q_des[k + 1] = q_des[k] + h * qd_des[k]\n",
        "\n",
        "        disturbance = push if (t_push_start <= t[k] <= t_push_end) else np.zeros(2)\n",
        "        qdd_act = Kp_ll @ (q_des[k] - q_act[k]) + Kd_ll @ (qd_des[k] - qd_act[k]) + disturbance\n",
        "\n",
        "        qd_act[k + 1] = qd_act[k] + h * qdd_act\n",
        "        q_act[k + 1] = q_act[k] + h * qd_act[k]\n",
        "\n",
        "    return q_act, q_des\n",
        "\n",
        "q_act_clock, q_des_clock = simulate(\"clock_only\")\n",
        "q_act_feedback, q_des_feedback = simulate(\"feedback\")\n",
        "\n",
        "# 3) Visualize ACTUAL states (solid) and desired states (dashed)\n",
        "fig, axes = plt.subplots(1, 2, figsize=(12, 5), constrained_layout=True)\n",
        "datasets = [\n",
        "    (\"Clock-Only DMP Input\", q_act_clock, q_des_clock),\n",
        "    (\"Feedback DMP Input\", q_act_feedback, q_des_feedback),\n",
        "]\n",
        "\n",
        "p0 = np.argmin(np.abs(t - t_push_start))\n",
        "p1 = np.argmin(np.abs(t - t_push_end))\n",
        "\n",
        "all_x = np.concatenate([q_demo[:, 0], q_act_clock[:, 0], q_des_clock[:, 0], q_act_feedback[:, 0], q_des_feedback[:, 0]])\n",
        "all_y = np.concatenate([q_demo[:, 1], q_act_clock[:, 1], q_des_clock[:, 1], q_act_feedback[:, 1], q_des_feedback[:, 1]])\n",
        "pad = 0.2\n",
        "xlim = (all_x.min() - pad, all_x.max() + pad)\n",
        "ylim = (all_y.min() - pad, all_y.max() + pad)\n",
        "\n",
        "for ax, (title, q_act, q_des) in zip(axes, datasets):\n",
        "    ax.plot(q_des[:, 0], q_des[:, 1], \"--\", color=\"gray\", linewidth=2, label=\"desired state\")\n",
        "    ax.plot(q_act[:, 0], q_act[:, 1], color=\"tab:blue\", linewidth=2.5, label=\"actual state\")\n",
        "    ax.scatter(q_demo[0, 0], q_demo[0, 1], color=\"black\", s=35, label=\"start\")\n",
        "    ax.scatter(g[0], g[1], color=\"crimson\", marker=\"*\", s=80, label=\"goal\")\n",
        "    ax.scatter(q_act[p0, 0], q_act[p0, 1], color=\"tab:red\", marker=\"x\", s=70, label=\"perturbation start\")\n",
        "    ax.scatter(q_act[p1, 0], q_act[p1, 1], color=\"tab:purple\", marker=\"x\", s=70, label=\"perturbation end\")\n",
        "    ax.set_title(title)\n",
        "    ax.set_xlabel(r\"$q_1$\")\n",
        "    ax.set_ylabel(r\"$q_2$\")\n",
        "    ax.set_aspect(\"equal\", adjustable=\"box\")\n",
        "    ax.set_xlim(*xlim)\n",
        "    ax.set_ylim(*ylim)\n",
        "    ax.grid(alpha=0.3)\n",
        "    ax.legend(loc=\"best\", fontsize=8)\n",
        "\n",
        "plt.show()"
      ],
